{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=YurtDb;Username=postgres;Password=postgres;Pooling=true;"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "yurt-api",
    "Audience": "yurt-clients",
    "ExpiryDays": "7"
  },
  "AllowedOrigins": [
    "http://localhost:4200",
    "http://localhost:4300",
    "capacitor://localhost"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Payment": {
    "WebhookCallbackUrl": "http://localhost:5000/api/payments/webhook",
    "WebhookSecret": "CHANGE_THIS_TO_A_LONG_SECRET",
    "SandboxSecret": "CHANGE_THIS_TO_A_DIFFERENT_SECRET",
    "SandboxBaseUrl": "https://kaspi.sandbox.example",
    "ProcessingDelaySecondsMin": 2,
    "ProcessingDelaySecondsMax": 10,
    "DuplicateWebhookChance": 0.05,
    "NetworkFailureChance": 0.05
  }
}
