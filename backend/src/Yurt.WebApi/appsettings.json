{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=YurtDb;Username=postgres;Password=2788;Pooling=true;"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "yurt-api",
    "Audience": "yurt-clients",
    "AccessTokenMinutes": "15",
    "RefreshTokenDays": "7"
  },
  "AllowedOrigins": [
    "http://localhost:4200",
    "http://localhost:4300",
    "capacitor://localhost",
    "https://altyncup.vercel.app",
    "https://altyncup-i71j.vercel.app",
    "https://www.altyncup.kz"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/yurt-.log",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "POST:/api/auth/login", "Period": "1m", "Limit": 10 },
      { "Endpoint": "POST:/api/auth/register", "Period": "1m", "Limit": 5 },
      { "Endpoint": "POST:/api/auth/verify-pin", "Period": "1m", "Limit": 10 }
    ]
  },
  "Payment": {
    "WebhookCallbackUrl": "http://localhost:5000/api/payments/webhook",
    "WebhookSecret": "CHANGE_THIS_TO_A_LONG_SECRET",
    "SandboxSecret": "CHANGE_THIS_TO_A_DIFFERENT_SECRET",
    "SandboxBaseUrl": "https://kaspi.sandbox.example",
    "ProcessingDelaySecondsMin": 2,
    "ProcessingDelaySecondsMax": 10,
    "DuplicateWebhookChance": 0.05,
    "NetworkFailureChance": 0.05
  }
}
